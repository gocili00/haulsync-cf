# Copy to .env (never commit .env)
# Used by: npm run db:push:env
# This file is for drizzle-kit CLI only — NOT the Worker runtime.
#
# Use your Supabase DIRECT connection string (port 5432):
# Found in: Supabase dashboard -> Settings -> Database -> Connection string -> URI
#
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres
